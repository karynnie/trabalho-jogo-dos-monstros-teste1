void perderVida() {
    vidas--;
    if (vidas <= 0) {
        limpar();
        printf(ANSI_BOLD ANSI_RED "====================================================\n" ANSI_RESET);
        printf(ANSI_BOLD ANSI_RED "                    GAME OVER\n" ANSI_RESET);
        printf(ANSI_BOLD ANSI_RED "====================================================\n\n" ANSI_RESET);
        printf(" O heroi tombou nas profundezas antes de alcançar sua redencao.\n");
        jogoRodando = 0;
        pausar();
    } else {
        printf(ANSI_BOLD ANSI_RED "\nVoce foi atingido! Perdeu 1 vida. Vidas Restantes: %d\n" ANSI_RESET, vidas);
        pausar();
    }
}

void vila() {
    char mapa[MAX][MAX];
    char comando;
    int nx, ny, fx, fy;

    inicializarMapa(mapa, 10);
    px = 5; py = 5; direcao = 'v';
    mapa[3][3] = 'N'; 
    mapa[1][8] = 'L'; 

    while (jogoRodando) {
        mostrarMapa(mapa, 10, "VILA INICIAL");
        printf("\nComando: ");
        scanf(" %c", &comando);
        getchar();

        nx = px; ny = py;
        if (comando == 'q' || comando == 'Q') { jogoRodando = 0; return; }

        if (comando == 'w' || comando == 'W') { direcao = '^'; nx--; }
        else if (comando == 's' || comando == 'S') { direcao = 'v'; nx++; }
        else if (comando == 'a' || comando == 'A') { direcao = '<'; ny--; }
        else if (comando == 'd' || comando == 'D') { direcao = '>'; ny++; }
        else if (comando == 'i' || comando == 'I') {
            fx = frenteX(); fy = frenteY();
            if (mapa[fx][fy] == 'N') {
                escolherArma();
            } else if (mapa[fx][fy] == 'L') {
                if (arma == 0) {
                    printf(ANSI_RED "\nVoce precisa falar com o Guardiao antes de entrar na masmorra.\n" ANSI_RESET);
                    pausar();
                } else {
                    return;
                }
            } else {
                printf("\nNao ha nada para interagir na sua frente.\n");
                pausar();
            }
        }

        if (mapa[nx][ny] == '*' || mapa[nx][ny] == 'N' || mapa[nx][ny] == 'L') {
            if (comando == 'w' || comando == 'a' || comando == 's' || comando == 'd' ||
                comando == 'W' || comando == 'A' || comando == 'S' || comando == 'D') {
                printf("\nCaminho bloqueado. Interaja usando 'I'.\n");
                pausar();
            }
        } else {
            px = nx; py = ny;
        }
    }
}

void destruirCelula(char mapa[MAX][MAX], int x, int y, int tamanho) {
    if (x >= 0 && x < tamanho && y >= 0 && y < tamanho) {
        if (mapa[x][y] == 'X' || mapa[x][y] == 'Y' || mapa[x][y] == 'Z' || mapa[x][y] == 'k') {
            mapa[x][y] = '.';
        }
    }
}

void ataque(char mapa[MAX][MAX], int tamanho) {
    int i, j, ax, ay;

    if (arma == 1) { 
        for (i = 1; i <= 2; i++) {
            if (direcao == '^') {
                ax = px - i; for (j = py - 1; j <= py + 1; j++) destruirCelula(mapa, ax, j, tamanho);
            } else if (direcao == 'v') {
                ax = px + i; for (j = py - 1; j <= py + 1; j++) destruirCelula(mapa, ax, j, tamanho);
            } else if (direcao == '<') {
                ay = py - i; for (j = px - 1; j <= px + 1; j++) destruirCelula(mapa, j, ay, tamanho);
            } else if (direcao == '>') {
                ay = py + i; for (j = px - 1; j <= px + 1; j++) destruirCelula(mapa, j, ay, tamanho);
            }
        }
        printf(ANSI_GREEN "\nVoce desferiu um corte amplo com a Espada!\n" ANSI_RESET);
    } else if (arma == 2) { 
        for (i = 1; i <= 4; i++) {
            ax = px; ay = py;
            if (direcao == '^') ax -= i;
            if (direcao == 'v') ax += i;
            if (direcao == '<') ay -= i;
            if (direcao == '>') ay += i;
            destruirCelula(mapa, ax, ay, tamanho);
        }
        printf(ANSI_GREEN "\nVoce disparou uma flecha veloz!\n" ANSI_RESET);
    } else if (arma == 3) { 
        for (i = px - 1; i <= px + 1; i++) {
            for (j = py - 1; j <= py + 1; j++) {
                if (!(i == px && j == py)) destruirCelula(mapa, i, j, tamanho);
            }
        }
        printf(ANSI_GREEN "\numa explosao magica emanou do seu Cajado!\n" ANSI_RESET);
    } else {
        printf("\nVoce nao tem armas equipadas para atacar!\n");
    }
    pausar();
}

void atualizarInimigos(char mapa[MAX][MAX], int tamanho) {
    int i, j;
    int movido[MAX][MAX];

    for (i = 0; i < tamanho; i++) {
        for (j = 0; j < tamanho; j++) {
            movido[i][j] = 0;
        }
    }

    for (i = 1; i < tamanho - 1; i++) {
        for (j = 1; j < tamanho - 1; j++) {
            if (movido[i][j]) continue;

            if (mapa[i][j] == 'X') {
                int dir = rand() % 4;
                int nx = i, ny = j;
                if (dir == 0) nx--;
                else if (dir == 1) nx++;
                else if (dir == 2) ny--;
                else ny++;

                if (nx == px && ny == py) { perderVida(); return; }
                if (mapa[nx][ny] == '.') {
                    mapa[nx][ny] = 'X'; mapa[i][j] = '.';
                    movido[nx][ny] = 1;
                }
            }
            else if (mapa[i][j] == 'Y') {
                int nx = i, ny = j;
                if (abs(px - i) > abs(py - j)) {
                    if (px > i) nx++; else nx--;
                } else {
                    if (py > j) ny++; else ny--;
                }

                if (nx == px && ny == py) { perderVida(); return; }
                if (mapa[nx][ny] == '.') {
                    mapa[nx][ny] = 'Y'; mapa[i][j] = '.';
                    movido[nx][ny] = 1;
                }
            }
            else if (mapa[i][j] == 'Z') {
                int nx = i, ny = j;
                if (px > i) nx++; else if (px < i) nx--;
                if (py > j) ny++; else if (py < j) ny--;

                if (nx == px && ny == py) { perderVida(); return; }
                if (mapa[nx][ny] == '.') {
                    mapa[nx][ny] = 'Z'; mapa[i][j] = '.';
                    movido[nx][ny] = 1;
                }
            }
        }
    }
}

int bossVivo(char mapa[MAX][MAX], int tamanho) {
    int i, j;
    for (i = 0; i < tamanho; i++) {
        for (j = 0; j < tamanho; j++) {
            if (mapa[i][j] == 'Z') return 1;
        }
    }
    return 0;
}

int jogarAndar(int andar, int tamanho) {
    char mapa[MAX][MAX];
    char comando;
    int nx, ny, fx, fy;
    int r, c; 

    inicializarMapa(mapa, tamanho);
    px = 1; py = 1; direcao = 'v';
    temChave = 0;

    if (andar == 1) {
        mapa[2][2] = '@'; mapa[4][4] = 'D';
        mapa[3][3] = 'k'; mapa[8][8] = 'L';
    } else if (andar == 2) {
        mapa[2][2] = '@';   mapa[2][12] = '@';
        mapa[6][6] = 'D';   mapa[7][7] = 'D';
        mapa[4][4] = '#';   mapa[5][5] = 'O'; 
        mapa[8][8] = 'X';   mapa[13][13] = 'L';
    } else if (andar == 3) {
        mapa[2][2] = '@';   mapa[2][20] = '@';  mapa[20][2] = '@';
        mapa[5][5] = 'D';   mapa[10][10] = 'D'; mapa[15][15] = 'D';
        mapa[6][6] = '#';   mapa[7][8] = '#';   mapa[12][12] = 'O';
        mapa[8][8] = 'X';   mapa[14][14] = 'Y'; mapa[22][22] = 'Z';
    }

    while (jogoRodando) {
        if (andar == 1) mostrarMapa(mapa, tamanho, "PRIMEIRO ANDAR DA MASMORRA (TUTORIAL)");
        else if (andar == 2) mostrarMapa(mapa, tamanho, "SEGUNDO ANDAR DA MASMORRA");
        else mostrarMapa(mapa, tamanho, "TERCEIRO ANDAR - O DESAFIO FINAL");

        printf("\nComando: ");
        scanf(" %c", &comando);
        getchar();

        nx = px; ny = py;
        if (comando == 'q' || comando == 'Q') return 0;

        if (comando == 'w' || comando == 'W') { direcao = '^'; nx--; }
        else if (comando == 's' || comando == 'S') { direcao = 'v'; nx++; }
        else if (comando == 'a' || comando == 'A') { direcao = '<'; ny--; }
        else if (comando == 'd' || comando == 'D') { direcao = '>'; ny++; }
        else if (comando == 'o' || comando == 'O') { ataque(mapa, tamanho); }
        else if (comando == 'i' || comando == 'I') {
            fx = frenteX(); fy = frenteY();
            if (mapa[fx][fy] == '@') {
                temChave++; mapa[fx][fy] = '.';
                printf(ANSI_GREEN "\nVoce recolheu uma Chave!\n" ANSI_RESET); pausar();
            } else if (mapa[fx][fy] == 'D') {
                if (temChave > 0) {
                    temChave--; mapa[fx][fy] = '=';
                    printf(ANSI_GREEN "\nA porta pesada se abriu.\n" ANSI_RESET); pausar();
                } else {
                    printf(ANSI_RED "\nEsta trancada. Você precisa de uma Chave.\n" ANSI_RESET); pausar();
                }
            } else if (mapa[fx][fy] == 'O') {
                printf(ANSI_CYAN "\nVoce ouviu engrenagens se movendo remotamente!\n" ANSI_RESET);
                mapa[fx][fy] = '.'; 
                for (r = 0; r < tamanho; r++) {
                    for (c = 0; c < tamanho; c++) {
                        if (mapa[r][c] == 'D') mapa[r][c] = '=';
                    }
                }
                pausar();
            } else if (mapa[fx][fy] == 'L') {
                printf(ANSI_CYAN "\nVoce subiu as escadas rumo ao proximo nivel!\n" ANSI_RESET);
                pausar(); return 1;
            } else {
                printf("\nNada com que interagir aqui.\n"); pausar();
            }
        }

        if (mapa[nx][ny] == '*' || mapa[nx][ny] == 'D' || mapa[nx][ny] == 'k' ||
            mapa[nx][ny] == '@' || mapa[nx][ny] == 'O' || mapa[nx][ny] == 'L') {
            printf("\nObstaculo no caminho. Use 'I' para interagir ou 'O' para atacar.\n");
            pausar();
        } else if (mapa[nx][ny] == '#') {
            perderVida(); return 0; 
        } else if (mapa[nx][ny] == 'X' || mapa[nx][ny] == 'Y' || mapa[nx][ny] == 'Z') {
            perderVida(); return 0; 
        } else {
            px = nx; py = ny;
        }

        if (andar == 3 && !bossVivo(mapa, tamanho)) {
            limpar();
            printf(ANSI_BOLD ANSI_GREEN "===================================================================\n" ANSI_RESET);
            printf(ANSI_BOLD ANSI_GREEN "                        VITÓRIA ALCANÇADA!                         \n" ANSI_RESET);
            printf(ANSI_BOLD ANSI_GREEN "===================================================================\n\n" ANSI_RESET);
            printf(" Com um golpe final definitivo, a criatura cai sem forças no chao.\n");
            printf(" A nevoa escura que cobria a regiao começa a se dissipar rapidamente.\n\n");
            printf(ANSI_YELLOW " O heroi provou seu valor, conquistou sua redençao de volta perante o povo\n" ANSI_RESET);
            printf(ANSI_YELLOW " e agora pode finalmente retornar ao seu reino com sua honra restabelecida.\n\n" ANSI_RESET);
            printf(ANSI_BOLD ANSI_WHITE " Obrigado por jogar!\n" ANSI_RESET);
            printf(ANSI_GREEN "===================================================================\n" ANSI_RESET);
            jogoRodando = 0;
            pausar();
            return 2;
        }

        atualizarInimigos(mapa, tamanho);
        if (!jogoRodando) return 0;
    }
    return 0;
}

void jogar() {
    int resultado;
    vidas = 3; arma = 0; jogoRodando = 1;

    mostrarIntro();
    vila();

    if (arma == 0) return; 

    while (jogoRodando) {
        resultado = jogarAndar(1, 10);
        if (!jogoRodando) break;
        if (resultado == 0) continue; 

        resultado = jogarAndar(2, 15);
        if (!jogoRodando) break;
        if (resultado == 0) continue;

        resultado = jogarAndar(3, 25);
        if (resultado == 2 || !jogoRodando) break;
    }
}

