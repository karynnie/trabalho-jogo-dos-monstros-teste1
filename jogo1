void inicializarMapa(char mapa[MAX][MAX], int tamanho) {
    int i, j;
    for (i = 0; i < tamanho; i++) {
        for (j = 0; j < tamanho; j++) {
            mapa[i][j] = '.';
        }
    }
    for (i = 0; i < tamanho; i++) {
        mapa[0][i] = '*';
        mapa[tamanho - 1][i] = '*';
        mapa[i][0] = '*';
        mapa[i][tamanho - 1] = '*';
    }
}

void mostrarMapa(char mapa[MAX][MAX], int tamanho, char titulo[]) {
    int i, j;
    limpar();

    printf(ANSI_CYAN "====================================================\n" ANSI_RESET);
    printf(ANSI_BOLD ANSI_WHITE " %s\n" ANSI_RESET, titulo);
    printf(ANSI_CYAN "====================================================\n" ANSI_RESET);
    
    printf(ANSI_BOLD ANSI_RED "Vidas: %d" ANSI_RESET " | ", vidas);
    printf(ANSI_BOLD ANSI_GREEN);
    if (arma == 1) printf("Arma: Espada ??");
    else if (arma == 2) printf("Arma: Arco e Flecha ??");
    else if (arma == 3) printf("Arma: Cajado ??");
    else printf("Arma: Nenhuma ??");
    printf(ANSI_RESET " | " ANSI_BOLD ANSI_YELLOW "Chaves: %d\n\n" ANSI_RESET, temChave);

    for (i = 0; i < tamanho; i++) {
        for (j = 0; j < tamanho; j++) {
            if (i == px && j == py) {
                printf(ANSI_BOLD ANSI_GREEN "%c " ANSI_RESET, direcao);
            } else {
                switch(mapa[i][j]) {
                    case '*': printf(ANSI_WHITE "%c " ANSI_RESET, mapa[i][j]); break;
                    case '#': printf(ANSI_RED "%c " ANSI_RESET, mapa[i][j]); break;
                    case 'k': printf(ANSI_YELLOW "%c " ANSI_RESET, mapa[i][j]); break;
                    case 'O': printf(ANSI_CYAN "%c " ANSI_RESET, mapa[i][j]); break;
                    case 'D': printf(ANSI_RED "%c " ANSI_RESET, mapa[i][j]); break;
                    case '=': printf(ANSI_GREEN "%c " ANSI_RESET, mapa[i][j]); break;
                    case '@': printf(ANSI_YELLOW "%c " ANSI_RESET, mapa[i][j]); break;
                    case 'L': printf(ANSI_CYAN "%c " ANSI_RESET, mapa[i][j]); break;
                    case 'N': printf(ANSI_MAGENTA "%c " ANSI_RESET, mapa[i][j]); break;
                    case 'X': 
                    case 'Y': printf(ANSI_BOLD ANSI_RED "%c " ANSI_RESET, mapa[i][j]); break;
                    case 'Z': printf(ANSI_BOLD ANSI_MAGENTA "%c " ANSI_RESET, mapa[i][j]); break;
                    default:  printf("%c ", mapa[i][j]); break;
                }
            }
        }
        printf("\n");
    }
    printf(ANSI_WHITE "\n Comandos: W/A/S/D = Mover | I = Interagir | O = Atacar | Q = Sair\n" ANSI_RESET);
}

int frenteX() {
    if (direcao == '^') return px - 1;
    if (direcao == 'v') return px + 1;
    return px;
}

int frenteY() {
    if (direcao == '<') return py - 1;
    if (direcao == '>') return py + 1;
    return py;
}
