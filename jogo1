void jogar() {
    int resultado;

    vidas = 3;
    arma = 0;
    jogoRodando = 1;

    mostrarIntro();
    vila();

    if (arma == 0) {
        printf("\nVoce saiu da vila sem escolher uma arma.\n");
        pausar();
        return;
    }

    while (jogoRodando) {
        resultado = jogarAndar(1, 10);
        if (!jogoRodando) break;
        if (resultado == 0) continue;

        resultado = jogarAndar(2, 15);
        if (!jogoRodando) break;
        if (resultado == 0) continue;

        resultado = jogarAndar(3, 25);
        if (resultado == 2) break;
        if (!jogoRodando) break;
    }
}

int main() {
    int opcao;

    srand(time(NULL));

    do {
        limpar();

        printf("====================================================\n");
        printf("              O HEROI DA REDENCAO\n");
        printf("====================================================\n");
        printf("        Uma aventura em busca de honra\n");
        printf("====================================================\n\n");

        printf("[1] Iniciar Jornada\n");
        printf("[2] Tutorial\n");
        printf("[3] Creditos\n");
        printf("[4] Sair\n\n");

        printf("Escolha uma opcao: ");
        scanf("%d", &opcao);
        getchar();

        if (opcao == 1) {
            jogar();
        } else if (opcao == 2) {
            tutorial();
        } else if (opcao == 3) {
            creditos();
        } else if (opcao == 4) {
            printf("\nSaindo do jogo...\n");
        } else {
            printf("\nOpcao invalida.\n");
            pausar();
        }

    } while (opcao != 4);

    return 0;
}
